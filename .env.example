MINIREDIS_PORT=6379

# Docker container limit and Go runtime memory target.
MINIREDIS_MEMORY_MB=256

# Server limits.
MINIREDIS_MAX_CLIENTS=8000
MINIREDIS_MAX_VALUE_BYTES=1048576
MINIREDIS_GLOBAL_RATE_LIMIT_PER_SECOND=50000
MINIREDIS_IP_RATE_LIMIT_PER_SECOND=1000
MINIREDIS_READ_TIMEOUT=5s
MINIREDIS_WRITE_TIMEOUT=5s
MINIREDIS_IDLE_TIMEOUT=30s
